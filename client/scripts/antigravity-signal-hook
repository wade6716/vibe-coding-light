#!/usr/bin/env bash
# Antigravity 信号灯 Hook 包装脚本。
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# 加载 .env 环境变量文件（若存在，已有的环境变量将具有更高优先级）
if [[ -f "$ROOT_DIR/.env" ]]; then
  set -a; source "$ROOT_DIR/.env"; set +a
fi

export UV_CACHE_DIR="${SIGNAL_LIGHT_UV_CACHE_DIR:-/private/tmp/signal-light-uv-cache}"
export PYTHONDONTWRITEBYTECODE="${PYTHONDONTWRITEBYTECODE:-1}"

# 依次尝试使用 uv、已有的虚拟环境 Python 或者是系统 Python 来运行 CLI 适配命令
if [[ "${SIGNAL_LIGHT_USE_UV:-0}" == "1" ]] && command -v uv >/dev/null 2>&1; then
  exec uv run python -m signal_light antigravity-hook "$@"
fi

if [[ -x "$ROOT_DIR/.venv/bin/python" ]]; then
  exec "$ROOT_DIR/.venv/bin/python" -m signal_light antigravity-hook "$@"
fi

exec python3 -m signal_light antigravity-hook "$@"
